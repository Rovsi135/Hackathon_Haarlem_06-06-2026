# ---------------------------------------------------------------------------
# Maverx AI Training Builder — frontend environment
# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# ---------------------------------------------------------------------------

# When "true", the UI runs entirely on the deterministic in-browser mock API
# (src/api/mock.js). No backend required — ideal for demos and design work.
# When "false", the UI calls the real FastAPI backend at VITE_API_BASE.
VITE_MOCK_API=true

# Base path for the real backend API. Requests are made to `${VITE_API_BASE}/...`.
# Leave as "/api" to use the Vite dev-server proxy (see vite.config.js).
VITE_API_BASE=/api

# Backend target used by the dev-server proxy when VITE_MOCK_API=false.
VITE_API_TARGET=http://localhost:8000

# Default UI language: "en" or "nl".
VITE_DEFAULT_LANG=en
